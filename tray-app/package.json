    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/openai": "^1.0.0",
    "ai": "^4.0.0",
    "electron-store": "^8.0.0",
    "eventsource": "^3.0.0"
  }
}
