{
  "name": "obsidian-meeting-notes",
  "version": "0.1.0",
  "description": "Tray app for auto-recording meeting notes to Obsidian",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc && electron .",
    "build": "tsc",
